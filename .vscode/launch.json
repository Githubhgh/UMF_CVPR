{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Train P-Flow (indi_denoiser)",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/train_UMF.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "args": [
                "--cfg",
                "configs/config_pflow.yaml",
                "--cfg_assets",
                "configs/assets.yaml",
                "--batch_size",
                "64",
                "--nodebug"
            ]
        },
